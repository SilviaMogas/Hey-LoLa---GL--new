# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Admin
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""
FIREBASE_DATABASE_ID=""

# Resend
RESEND_API_KEY=""
EMAIL_FROM=""
EMAIL_REPLY_TO=""

# Optional override for the destination of every "admin alert" email
# (partner application, new signup, group join, etc). Defaults to
# hey@heylola.co. Useful for staging / QA environments where you want
# alerts in a different inbox without changing code.
ADMIN_INBOX_EMAIL=""
